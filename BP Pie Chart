import matplotlib.pyplot as plt

#SETUP
#Classify BP
def classify_bp(sys,dia):
    if sys < 90 or dia < 60:
        return "Low"
    elif sys >= 130 or dia >= 80:
        return "Elevated"
    else:
        return "Normal"

#Separate Counts
morning_counts = {"Low":0,"Elevated":0,"Normal":0}
evening_counts = {"Low":0,"Elevated":0,"Normal":0}

#Read file
try:
    with open("blood_pressure_dataset.txt", "r") as f:
        lines = f.readlines()
except FileNotFoundError:
    print ("File Not Found")
    exit()
#if file not found, directly insert file directory 

#MAINCODE
#Parse each line
for line in lines:
    if "Day" not in line:
        continue

    #Extract values
    parts = line.strip().split(",")

    morning = parts[0].split()[-1]
    evening = parts[1].split()[-1]

    #Integer conversion
    m_sys, m_dia = map(int,morning.split("/"))
    e_sys, e_dia = map(int,evening.split("/"))

    #Classify counts separately
    morning_counts[classify_bp(m_sys,m_dia)]+=1
    evening_counts[classify_bp(e_sys,e_dia)]+=1

#Generate 3 plots without showing 0% label
fig, axes = plt.subplots(1,3,figsize=(15,5))
def format_pct(pct):
    return f"{pct:.2f}%" if pct > 0 else""

#Filter out categories with 0%
def filter_zero_counts(counts_dict):
    labels = []
    values = []
    for k,v in counts_dict.items():
        if v > 0:
            labels.append(k)
            values.append(v)
    return labels, values

#Morning Chart
labels_m, values_m = filter_zero_counts(morning_counts)
axes[0].pie(
    values_m,
    labels = labels_m,
    explode=[0.05]*len(values_m),
    autopct=format_pct
)
axes[0].set_title("Morning BP Distribution")

#Evening Chart
labels_e, values_e = filter_zero_counts(evening_counts)
axes[1].pie(
    values_e,
    labels = labels_e,
    explode=[0.05]*len(values_e),
    autopct=format_pct
)
axes[1].set_title("Evening BP Distribution")

#Total Chart
total_counts = {
    "Low": morning_counts["Low"] + evening_counts["Low"],
    "Normal": morning_counts["Normal"] + evening_counts["Normal"],
    "Elevated": morning_counts["Elevated"] + evening_counts["Elevated"],
}
labels_t, values_t = filter_zero_counts(total_counts)
axes[2].pie(
    values_t,
    labels = labels_t,
    explode=[0.05]*len(values_t),
    autopct=format_pct
)
axes[2].set_title("Total BP Distribution")
    
plt.show()
